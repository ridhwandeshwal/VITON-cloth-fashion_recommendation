NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

HD_VITON_DIR=backend/HD-ViTON/VITON-HD

# Modal-hosted GPU services (see modal_apps/). Fill these in after running
# `modal deploy modal_apps/nst_app.py` and `modal deploy modal_apps/idm_vton_app.py`.
MODAL_NST_URL=
MODAL_VTON_URL=
MODAL_PROXY_TOKEN_ID=
MODAL_PROXY_TOKEN_SECRET=

# Deploy-time knobs, not secrets — set these as actual env vars on the host
# (docker run -e / --env-file), not needed here for local dev. See Dockerfile.
# PORT=8000
# WEB_CONCURRENCY=2
